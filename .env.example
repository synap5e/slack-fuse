# slack-fuse configuration
#
# Copy this file to .env and fill in your tokens. The .env file is loaded
# by the systemd service via EnvironmentFile= and is gitignored.

# Required: Slack user token (xoxc-... or xoxp-...). The mount runs as you
# and reads everything you can read in the workspace.
SLACK_USER_TOKEN=xoxc-your-user-token-here

# Optional: app-level token for socket-mode features (xapp-...). Leave unset
# or use the placeholder if you don't have one.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Optional: bot token (xoxb-...). Slack requires the app to have a bot user
# for Socket Mode, but every event slack-fuse subscribes to is user-scope,
# so the bot token's scopes don't matter. Any scope is fine.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Optional: workspace base URL (e.g. https://your-workspace.slack.com).
# Only used by `slack-fuse permalink` for channel-root URLs — message-level
# permalinks go through Slack's chat.getPermalink and don't need this.
# SLACK_WORKSPACE_URL=https://your-workspace.slack.com

# Optional: override the FUSE mountpoint used by `slack-fuse mount`, `resolve`,
# and `permalink`. Defaults to ~/views/slack. Most users won't need this — set
# it only if you mount somewhere else (e.g. a top-level /views/slack).
# SLACK_FUSE_MOUNTPOINT=/views/slack

# Background backfill of historical messages into the disk cache.
# When enabled, slowly paginates full history for each member channel
# (long random sleeps between calls to stay under rate limits) and
# resumes across restarts via marker files in ~/.cache/slack-fuse/backfill/.
# Accepts: true/false, 1/0, yes/no, on/off. Default if unset: true.
SLACK_FUSE_BACKFILL=false
